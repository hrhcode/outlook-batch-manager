{
  "name": "core-gateway",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "desktop",
    "ui"
  ],
  "scripts": {
    "dev": "python startup.py",
    "dev:ui": "npm run dev --workspace ui",
    "dev:desktop": "npm run dev --workspace desktop",
    "build": "npm run build --workspace ui && npm run build --workspace desktop",
    "test": "npm run test --workspace ui && python -m pytest backend/tests",
    "typecheck": "npm run typecheck --workspace ui",
    "lint": "npm run test --workspace desktop"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}

